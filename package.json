{
  "name": "@laplace.live/facet",
  "version": "0.0.4",
  "description": "Tiny parser for Gmail-style faceted search queries",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "test": "bun test --timeout 5000",
    "bench": "bun run bench/index.ts",
    "prepublishOnly": "bun run build",
    "release": "changeset publish",
    "version": "changeset version",
    "lint": "biome check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laplace-live/facet.git"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/laplace-live/facet#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "mitata": "^1.0.34",
    "search-query-parser": "^1.6.0",
    "search-string": "^4.1.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3"
  }
}
